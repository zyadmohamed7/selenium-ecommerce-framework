<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Exercise Test Suite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.seleniumframework.listeners.TestListener"/>
        <listener class-name="com.seleniumframework.listeners.RetryTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="E2E Tests">
        <classes>
            <class name="com.seleniumframework.tests.E2ETests"/>
        </classes>
    </test>

</suite>
